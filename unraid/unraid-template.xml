<?xml version="1.0"?>
<Container version="2">
  <Name>statesync</Name>
  <Repository>ghcr.io/ubermetroid/statesync:latest</Repository>
  <Registry>https://github.com/UberMetroid/statesync/pkgs/container/statesync</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/UberMetroid/statesync/issues</Support>
  <Project>https://github.com/UberMetroid/statesync</Project>
  <Overview>Real-time bi-directional Emby/Jellyfin watch-state sync. Web UI on port 8754.</Overview>
  <Category>MediaApp:Video MediaApp:Other</Category>
  <Icon>https://raw.githubusercontent.com/UberMetroid/statesync/master/graphics/statesync_icon.jpg</Icon>
  <WebUI>http://[IP]:[PORT:8754]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/UberMetroid/statesync/master/unraid/unraid-template.xml</TemplateURL>

  <Config Name="WebUI Port" Target="8754" Default="8754" Mode="tcp" Description="Web interface port." Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="Config Volume" Target="/config" Default="/mnt/user/appdata/statesync" Mode="rw" Description="Persistent directory for config.json." Type="Path" Display="always" Required="true" Mask="false"/>

  <Config Name="Log Level" Target="RUST_LOG" Default="info" Mode="" Description="Log level (info, warn, error, debug)" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="UTC" Mode="" Description="Container timezone (e.g. America/New_York)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Allow Insecure HTTP" Target="STATESYNC_ALLOW_INSECURE_HTTP" Default="true" Mode="" Description="Allow plain http:// URLs to upstream Emby/Jellyfin servers. Default true (LAN). Set false to force https:// only." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Web UI Bearer Token" Target="STATESYNC_WEB_AUTH" Default="" Mode="" Description="Optional. Format: bearer:&lt;token&gt;. Generate with: openssl rand -hex 32. Leave blank for open LAN access." Type="Variable" Display="advanced" Required="false" Mask="true"/>
</Container>