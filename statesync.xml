<?xml version='1.0' encoding='utf-8'?>
<Container version="2">
  <Name>statesync</Name>
  <Repository>ghcr.io/studio2201/statesync:latest</Repository>
  <Registry>https://github.com/studio2201/statesync/pkgs/container/statesync</Registry>
  <Network>host</Network>
  <MyIP />
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/statesync/issues</Support>
  <Project>https://github.com/studio2201/statesync</Project>
  <Overview>Real-time bi-directional Emby and Jellyfin watch-state sync.</Overview>
  <Category>MediaApp:Video MediaApp:Other</Category>
  <WebUI>http://[IP]:[PORT:4601]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/statesync/master/unraid/unraid-template.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/statesync/master/graphics/statesync_icon.jpg</Icon>
  <ExtraParams />
  <PostArgs />
  <CPUset />
  <DateInstalled />
  <DonateText />
  <DonateLink />
  <Requires />
  <Description>StateSync keeps Emby and Jellyfin playback progress and played flags in sync. HOST NETWORK: dashboard at http://YOUR-UNRAID-IP:4601. AUTH: leave Dashboard Auth empty on first start to auto-generate a token (printed in the container log and saved under appdata/.web_auth). Paste the hex token into the WebUI (no bearer: prefix). After start: ADD MODULE for Emby and Jellyfin with URL + API key.</Description>
  <Config Name="Web UI Port" Target="4601" Default="4601" Mode="tcp" Description="Dashboard port. Open http://UNRAID-IP:4601 after start." Type="Port" Display="always" Required="true" Mask="false">4601</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/statesync" Mode="rw" Description="Host path for config.json. Persists across updates." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/statesync</Config>
  <Config Name="Timezone" Target="TZ" Default="America/New_York" Mode="" Description="Timezone for log timestamps." Type="Variable" Display="always" Required="false" Mask="false">America/New_York</Config>
  <Config Name="Dashboard Auth" Target="STATESYNC_WEB_AUTH" Default="" Mode="" Description="Leave empty for first start (auto token in log and appdata/.web_auth). Or set bearer:YOURTOKEN." Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="User ID. Default 99 = Unraid nobody." Type="Variable" Display="advanced" Required="false" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Group ID. Default 100 = Unraid users." Type="Variable" Display="advanced" Required="false" Mask="false">100</Config>
  <Config Name="UMASK" Target="UMASK" Default="022" Mode="" Description="File creation mask. Default 022." Type="Variable" Display="advanced" Required="false" Mask="false">022</Config>
  <Config Name="Log Level" Target="RUST_LOG" Default="info" Mode="" Description="Log verbosity: info or debug." Type="Variable" Display="advanced" Required="false" Mask="false">info</Config>
  <Config Name="Bind Address" Target="STATESYNC_BIND" Default="0.0.0.0:4601" Mode="" Description="Listen address. Default 0.0.0.0:4601." Type="Variable" Display="advanced" Required="false" Mask="false">0.0.0.0:4601</Config>
  <Config Name="Allow HTTP to media servers" Target="STATESYNC_ALLOW_INSECURE_HTTP" Default="true" Mode="" Description="Allow plain http to Emby/Jellyfin on LAN." Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
  <Config Name="Accept Invalid TLS Certs" Target="STATESYNC_ACCEPT_INVALID_CERTS" Default="false" Mode="" Description="true only for self-signed HTTPS you trust." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="Fuzzy User Match" Target="STATESYNC_FUZZY_USER_MATCH" Default="false" Mode="" Description="true allows substring username matching." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="Force Sync Rate" Target="STATESYNC_FORCE_RATE" Default="5" Mode="" Description="Items per second during FORCE SYNC (1 to 50)." Type="Variable" Display="advanced" Required="false" Mask="false">5</Config>
  <Config Name="Sync Threshold Seconds" Target="STATESYNC_SYNC_THRESHOLD_SECONDS" Default="5" Mode="" Description="Skip redundant updates within this many seconds." Type="Variable" Display="advanced" Required="false" Mask="false">5</Config>
</Container>
